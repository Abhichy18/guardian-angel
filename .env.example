# Guardian Angel — Environment Variables
# Copy this file to .env and fill in your values.

# ── LLM Provider ──────────────────────────────────────────────
# OpenRouter API key for the orchestrator agent
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use via OpenRouter (default: google/gemini-2.0-flash-001)
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ── Application ───────────────────────────────────────────────
# Secret key for JWT token signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change_me_to_a_random_secret_key

# Database path (SQLite)
DATABASE_URL=sqlite:///./guardian_angel.db

# ── Server ────────────────────────────────────────────────────
# Backend server host and port
HOST=0.0.0.0
PORT=8000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
